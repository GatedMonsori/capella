{
  "manifest_version": 3,
  "name": "Capella",
  "version": "1.1.0",
  "description": "Capella — une interface claire et lisible par-dessus Auriga (Aurion) d'EPITA : notes, moyennes, coefficients, libellés compréhensibles.",
  "content_scripts": [
    {
      "matches": ["https://auriga.epita.fr/*"],
      "js": ["src/capture.js"],
      "run_at": "document_start",
      "world": "MAIN"
    },
    {
      "matches": ["https://auriga.epita.fr/*"],
      "js": ["src/ui.js"],
      "css": ["src/ui.css"],
      "run_at": "document_idle",
      "world": "MAIN"
    }
  ]
}
