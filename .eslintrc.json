{
  "root": true,
  "env": { "browser": true, "es2021": true },
  "parserOptions": { "ecmaVersion": 2021, "sourceType": "script" },
  "extends": "eslint:recommended",
  "rules": {
    "eqeqeq": ["warn", "smart"],
    "no-empty": ["error", { "allowEmptyCatch": true }],
    "no-unused-vars": ["warn", { "args": "none" }],
    "no-var": "off",
    "prefer-const": "off",
    "no-console": "off",
    "complexity": ["warn", 15],
    "max-depth": ["warn", 4],
    "no-eval": "error"
  },
  "globals": { "chrome": "readonly" }
}
